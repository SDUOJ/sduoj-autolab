# 远程同步配置示例，将本文件复制为 .env 并填写真实值

# 远程服务器地址（IP 或域名）
REMOTE_HOST=example.com

# 远程登录用户名
REMOTE_USER=user

# 远程登录密码（用于 sshpass）。如服务器禁用密码登录，建议改用密钥并调整脚本。
REMOTE_PASSWORD=your_password_here

# 远程目标目录，脚本会确保该目录存在
REMOTE_PATH=/var/www/sduoj-autolab

# 可选：SSH 端口，默认为 22
# REMOTE_PORT=22

# 可选：本地源目录，默认为脚本所在仓库根目录
# SOURCE_DIR=/absolute/path/to/sduoj-autolab

# 可选：设为 1 以仅预览同步（不实际上传）
# DRY_RUN=1